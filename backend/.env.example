# ============================================
# VidyaAI Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (change this to a random long string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

# ============================================
# Azure OpenAI Configuration
# Get from: Azure Portal > Azure OpenAI resource > Keys and Endpoint
# ============================================
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ============================================
# Azure SQL Database
# Get from: Azure Portal > SQL Database > Connection strings
# ============================================
DB_SERVER=your-server.database.windows.net
DB_NAME=vidyaai_db
DB_USER=vidyaai_admin
DB_PASSWORD=your_strong_password_here
DB_PORT=1433

# ============================================
# Microsoft Entra ID (Azure AD) - Optional Auth
# ============================================
AZURE_AD_TENANT_ID=your_tenant_id
AZURE_AD_CLIENT_ID=your_client_id
AZURE_AD_CLIENT_SECRET=your_client_secret

# ============================================
# Frontend URL (for CORS)
# ============================================
FRONTEND_URL=http://localhost:3000
